<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AeroLink.ViewModels"
             x:Class="AeroLink.Views.MainView"
             x:DataType="vm:MainWindowViewModel"
             Background="{DynamicResource SystemRegionBrush}">

    <SplitView IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
               DisplayMode="Overlay"
               OpenPaneLength="300"
               PaneBackground="{DynamicResource SystemRegionBrush}">
        
        <SplitView.Pane>
            <Grid RowDefinitions="Auto, *, Auto" Margin="15">
                <TextBlock Grid.Row="0" Text="Профили" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                
                <ListBox Grid.Row="1" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Engine}" FontSize="12" Foreground="Gray"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="❌" Background="Transparent"
                                        Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).DeleteProfileCommand}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2" Content="Закрыть меню" 
                        Command="{Binding TogglePaneCommand}"
                        HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
            </Grid>
        </SplitView.Pane>

        <Grid RowDefinitions="Auto, *, Auto" Margin="20">
            
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *">
                <Button Grid.Column="0" Content="☰" FontSize="24" Background="Transparent" 
                        Command="{Binding TogglePaneCommand}"/>
                <TextBlock Grid.Column="1" Text="AeroLink VPN" FontSize="24" FontWeight="Bold" 
                           Foreground="#0078D7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="20">
                <TextBlock Text="{Binding ConnectionTimeText}" FontSize="24" HorizontalAlignment="Center"/>
                <Button Content="{Binding ActionButtonText}" 
                        Command="{Binding ToggleConnectionCommand}"
                        Width="220" Height="60" CornerRadius="30" 
                        Background="#0078D7" Foreground="White"
                        HorizontalAlignment="Center" HorizontalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Spacing="10">
                <TextBox Text="{Binding RawConfigText}" 
                         Height="80" Watermark="Вставьте vpn:// ссылку или текст..." 
                         AcceptsReturn="True" CornerRadius="10"/>
                
                <Grid ColumnDefinitions="*, *">
                    <Button Grid.Column="0" Content="Добавить ссылку" 
                            Command="{Binding ParseConfigCommand}"
                            HorizontalAlignment="Stretch" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="Файл .conf" 
                            Click="OpenFileButton_Click"
                            HorizontalAlignment="Stretch" Margin="5,0,0,0"/>
                </Grid>
            </StackPanel>
        </Grid>
    </SplitView>
</UserControl>